# Скопируйте в `.env` в корне репозитория и подставьте значения. Файл `.env` в git не коммитится.
# Геокод координат и уезда: Geoapify (основной) + OpenCage (fallback).
GEOAPIFY_API_KEY=
OPENCAGE_API_KEY=
# Google Geocoding — последний fallback.
GOOGLE_MAPS_GEOCODING_API_KEY=
# Пауза между запросами OpenCage при --infer-county (сек).
# OPENCAGE_MIN_DELAY_SEC=1.1
