# Cloudflare Pages headers — copied into the build output by @cloudflare/next-on-pages.
# Data and font files are immutable; snapshot must be cache-busted via a query
# string (see Dashboard.tsx snapshot fetch) or by renaming when contents change.

/data/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/logo.svg
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=86400
